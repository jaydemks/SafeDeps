<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net8.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PackAsTool>true</PackAsTool>
    <ToolCommandName>safedeps-dotnet</ToolCommandName>
    <PackageId>SafeDeps.Tool</PackageId>
    <PackageVersion>0.3.3</PackageVersion>
    <Authors>Giovanni De Miccoli</Authors>
    <Description>SafeDeps .NET global tool wrapper for the SafeDeps CLI.</Description>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <PackageTags>security;dependencies;supply-chain;sbom;nuget</PackageTags>
    <RepositoryUrl>https://github.com/jaydemks/SafeDeps</RepositoryUrl>
  </PropertyGroup>
</Project>
